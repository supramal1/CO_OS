# ---------------------------------------------------------------------------
# Charlie Oscar OS — local development environment
# ---------------------------------------------------------------------------
# Copy to .env.local and fill in.
# NEVER commit .env.local.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (create at console.cloud.google.com → APIs & Services → Credentials)
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cornerstone Memory API — superuser key for email resolution
CORNERSTONE_API_URL=https://cornerstone-api-lymgtgeena-nw.a.run.app
MEMORY_API_KEY=

# Cornerstone Agents service — Forge PM/Researcher/Builder orchestrator.
# The CO OS Forge kanban posts /invoke and /resume here when a human drags
# across a gated lane transition. Public-invoke Cloud Run service (no auth
# header required in current revision). Set CORNERSTONE_AGENTS_API_KEY if
# the backend gains auth later — the transition route will forward it as
# X-API-Key when present.
CORNERSTONE_AGENTS_URL=https://cornerstone-agents-lymgtgeena-nw.a.run.app
CORNERSTONE_AGENTS_API_KEY=

# Supabase — used by the Forge kanban for Realtime lane transitions
# (backend-driven PM → research_review, Builder → production_review,
# approval → done). Anon key is sufficient; reads are gated by RLS and
# the admin-only nav. Must be set in Vercel env before deploy.
NEXT_PUBLIC_SUPABASE_URL=https://bksxovxcbescoytwmghq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cookbook MCP
COOKBOOK_MCP_URL=https://co-cookbook-mcp-lymgtgeena-nw.a.run.app

# Additional emails permitted to sign in beyond @charlieoscar.com domain
# (comma-separated)
CO_OS_ALLOWED_EMAILS=

# Cookbook → Git export (admin "Export to Git" button opens a PR on this repo)
# GITHUB_TOKEN: a fine-grained PAT with Contents: write, Pull requests: write on
# the target repo below. Never commit this.
GITHUB_TOKEN=
COOKBOOK_GIT_REPO=supramal1/co-cookbook
COOKBOOK_GIT_BRANCH=main
# Optional — commits will use these as the author/committer
COOKBOOK_GIT_AUTHOR_NAME=co-os-bot
COOKBOOK_GIT_AUTHOR_EMAIL=co-os-bot@charlieoscar.com
